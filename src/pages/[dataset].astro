---
import DatasetTemplate from '../templates/datasetTemp.astro';
import App from '../components/App.tsx';
import appCssUrl from '../components/App.css?url';

export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { dataset: "csprofs" } },
    { params: { dataset: "students" } },
  ];
}

const { dataset } = Astro.params;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Drafty Prototype</title>
  </head>
  <body>
    <DatasetTemplate dataset={dataset} />
    <link rel="stylesheet" href={appCssUrl} />
    <App client:only="react" />
  </body>
</html>
